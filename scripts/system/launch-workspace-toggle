#!/usr/bin/env bash
# toggle-workspace-layout - Toggle between scrolling and default layout for current workspace

# Get current workspace
current_workspace=$(hyprctl activeworkspace -j | jq -r '.id')

# State file to track layout per workspace
STATE_FILE="/tmp/hypr/workspace-layouts.conf"

# Create state file if it doesn't exist
[ ! -f "$STATE_FILE" ] && touch "$STATE_FILE"

# Check current layout for this workspace
if grep -q "^workspace = $current_workspace, layout:scrolling" "$STATE_FILE"; then
    # Currently scrolling, switch to default
    sed -i "/^workspace = $current_workspace, layout:scrolling/d" "$STATE_FILE"
    hyprctl keyword workspace "$current_workspace, layout:default"
    notify-send "Workspace $current_workspace" "Layout: Default"
else
    # Currently default, switch to scrolling
    echo "workspace = $current_workspace, layout:scrolling" >> "$STATE_FILE"
    hyprctl keyword workspace "$current_workspace, layout:scrolling"
    notify-send "Workspace $current_workspace" "Layout: Scrolling"
fi
